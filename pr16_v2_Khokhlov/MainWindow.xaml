<Window x:Class="pr16_v2_Khokhlov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr16_v2_Khokhlov"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="Информация о студентах" FontSize="20" Background="Coral"/>
            <StackPanel Orientation="Horizontal">
                <Label Content="Фамилия" FontSize="11" Margin="10,0,0,0"/>
                <Label Content="Группа" FontSize="11" Margin="133,0,0,0"/>
                <Label Content="Специальность" FontSize="11" Margin="133,0,0,0"/>
                <Label Content="Дисциплина" FontSize="11" Margin="100,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtInput" FontSize="11" ToolTip="Введите текст" Margin="10,0,0,20" Width="166" />
                <TextBox x:Name="txtGroup" FontSize="11" Margin="25,0,10,20" Width="166"/>
                <TextBox x:Name="txtSpec" FontSize="11" Margin="5,0,10,20" Width="166"/>
                <TextBox x:Name="txtDisc" FontSize="11" Margin="5,0,10,20" Width="166"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Оценка" FontSize="11" Margin="10,0,0,0"/>
                <Label Content="Фильтр" FontSize="11" Margin="310,0,0,0"/>
                <Label Content="Сортировка" FontSize="11" Margin="134,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtMark" FontSize="11" Margin="10,0,0,20" Width="166"/>
                <TextBox x:Name="Filt_txt" Margin="190,0,0,20" FontSize="11" Width="166" TextChanged="Filt_txt_TextChanged"/>
                <ComboBox x:Name="Sort_cmb" FontSize="11" Width="166" Margin="15,0,0,20" SelectionChanged="Sort_cmb_SelectionChanged">
                    <ComboBoxItem Content="По алфавиту(А-Я)"/>
                    <ComboBoxItem Content="По алфавиту(Я-А)"/>
                    <ComboBoxItem Content="По группе"/>
                    <ComboBoxItem Content="По специальности" />
                    <ComboBoxItem Content="По дисциплине" />
                    <ComboBoxItem Content="По оценке (возрастание)" />
                    <ComboBoxItem Content="По оценке (убывание)" />
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <DataGrid x:Name="lst_box" Margin="10,0,0,0" Height="150" Width="690" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  SelectionMode="Single"
                          FontSize="11">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding Group}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Дисциплина" Binding="{Binding Discipline}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" Width="80" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
            <Button Content="Добавить в список" FontSize="11" Foreground="White" Click="Add_Click" Margin="576,0,0,0" Width="160" Background="Blue"/>
            <Button Content="Удалить из списка" FontSize="11" Foreground="White" Width="160" Click="Delete_lst" Margin="576,7,0,0" Background="Red"/>
            <Button FontSize="11" Foreground="White" Click="Clear_List" Background="Red" Content="Очистить список" Margin="576,7,0,0" Width="160"/>
            <Button FontSize="11" Foreground="White" Click="Save_List" Background="Blue" Content="Сохранить список" Margin="576,7,0,0" Width="160"/>
            <Button FontSize="11" Foreground="White" Click="Load_List" Background="Blue" Content="Загрузить список" Margin="576,7,0,0" Width="160"/>
        </StackPanel>
    </Grid>
</Window>
